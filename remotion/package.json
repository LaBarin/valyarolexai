{
  "name": "valyarolex-remotion",
  "version": "1.0.0",
  "description": "Remotion compositions for Valyarolex.AI video ad generator. Bundles to a Remotion Lambda site that renders 1920x1080/1080x1920/1080x1080 videos with voiceover, music, animated scenes, and a branded closing card.",
  "private": true,
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "build": "remotion bundle src/index.ts",
    "deploy:function": "remotion lambda functions deploy",
    "deploy:site": "remotion lambda sites create src/index.ts --site-name=valyarolex-ads",
    "render:local": "remotion render src/index.ts AdVideo out/test.mp4"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.250",
    "@remotion/cli": "4.0.250",
    "@remotion/lambda": "4.0.250",
    "@remotion/transitions": "4.0.250",
    "@remotion/google-fonts": "4.0.250",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.250",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/react": "18.3.3",
    "typescript": "5.5.3"
  }
}
